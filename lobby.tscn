[gd_scene format=3 uid="uid://dnpbysqoeq041"]

[sub_resource type="Theme" id="Theme_r5v3i"]

[sub_resource type="GDScript" id="GDScript_r5v3i"]
resource_name = "lobby.gd"
script/source = "extends Control

const PORT := 7000
const MAX_CLIENTS := 3

@onready var host_button = $VBoxContainer/Host_Button
@onready var join_button = $VBoxContainer/Join_Button
@onready var start_button = $VBoxContainer/Start_Button
@onready var ip_input = $VBoxContainer/Ip_Input
@onready var status_label = $VBoxContainer/Status_Label

var peer: ENetMultiplayerPeer


func _ready():
	status_label.text = \"Not Connected\"
	start_button.visible = false
	start_button.disabled = false

	host_button.pressed.connect(_on_host_button_pressed)
	join_button.pressed.connect(_on_join_button_pressed)
	start_button.pressed.connect(_on_start_button_pressed)

	multiplayer.peer_connected.connect(_on_peer_connected)
	multiplayer.peer_disconnected.connect(_on_peer_disconnected)
	multiplayer.connected_to_server.connect(_on_connected_to_server)
	multiplayer.connection_failed.connect(_on_connection_failed)
	multiplayer.server_disconnected.connect(_on_server_disconnected)


func _on_host_button_pressed():
	peer = ENetMultiplayerPeer.new()
	var error = peer.create_server(PORT, MAX_CLIENTS)

	if error != OK:
		status_label.text = \"Server baslatilamadi\"
		return

	multiplayer.multiplayer_peer = peer
	status_label.text = \"Host acildi. Oyuncu bekleniyor...\"

	host_button.disabled = true
	join_button.disabled = true
	ip_input.editable = false


func _on_join_button_pressed():
	var ip = ip_input.text.strip_edges()

	if ip == \"\":
		status_label.text = \"IP gir\"
		return

	peer = ENetMultiplayerPeer.new()
	var error = peer.create_client(ip, PORT)

	if error != OK:
		status_label.text = \"Baglanti baslatilamadi\"
		return

	multiplayer.multiplayer_peer = peer
	status_label.text = \"Baglaniliyor: \" + ip

	host_button.disabled = true
	join_button.disabled = true
	ip_input.editable = false


func _on_connected_to_server():
	status_label.text = \"Baglandi. Host oyunu baslatacak...\"


func _on_connection_failed():
	status_label.text = \"Connection failed\"
	_reset_ui()


func _on_server_disconnected():
	status_label.text = \"Server disconnected\"
	_reset_ui()


func _on_peer_connected(id):
	if multiplayer.is_server():
		start_button.visible = true
		start_button.disabled = false
		status_label.text = \"Oyuncu baglandi. Oyuna basla butonuna bas.\"


func _on_peer_disconnected(id):
	status_label.text = \"Oyuncu ayrildi: \" + str(id)

	if multiplayer.is_server():
		start_button.visible = false


func _on_start_button_pressed():
	if not multiplayer.is_server():
		return

	start_game.rpc()


@rpc(\"any_peer\", \"call_local\", \"reliable\")
func start_game():
	host_button.disabled = true
	join_button.disabled = true
	start_button.disabled = true
	ip_input.editable = false

	status_label.text = \"OYUN BASLIYOR!!\"

	await get_tree().create_timer(2.0).timeout
	get_tree().change_scene_to_file(\"res://GameScreen.tscn\")


func _reset_ui():
	host_button.disabled = false
	join_button.disabled = false
	ip_input.editable = true
	start_button.visible = false
	start_button.disabled = false
	status_label.text = \"Not Connected\"
"

